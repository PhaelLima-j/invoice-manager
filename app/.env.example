# Modelo de variáveis de ambiente — copie para app/.env e preencha.
# NÃO versione o app/.env real (ele está no .gitignore).

# Conexão com o PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/invoice_manager

# Chave usada para assinar os tokens JWT.
# Gere uma nova, por exemplo:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-aleatoria

# Algoritmo e expiração do token
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
